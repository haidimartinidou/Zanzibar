# Copy this file to .env for local development and fill in the values.

# Supabase client (public keys — safe to expose to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase backend (server-side only — never expose these)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used by the generate-playlist Supabase edge function
OPENAI_API_KEY=

# Spotify PKCE login
VITE_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_ID=

# Public site URL (e.g. https://your-app.example.com) — email-confirmation
# redirect target. Leave blank locally to fall back to window.location.origin.
VITE_SITE_URL=
